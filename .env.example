# 열쇠는 딱 세 개만 넣으면 된다.
# 나머지(상품 정보, 손익분기, 페이지·픽셀 등)는 클로드가 대화로 물어보고 config.json 에 채워준다.

# 1. 메타 광고 계정 열쇠
#    business.facebook.com > 설정 > 사용자 > 시스템 사용자 > 토큰 생성
#    권한: ads_management, ads_read, business_management
META_ADS_TOKEN=

# 2. 광고 계정 번호 (광고 관리자 주소창의 act= 뒤 숫자만, act_ 없이)
META_AD_ACCOUNT_ID=

# 3. 그림 생성 열쇠 (OpenAI)
OPENAI_API_KEY=
