# 메타 광고 계정 열쇠 (business.facebook.com > 설정 > 사용자 > 시스템 사용자)
# 권한: ads_management, ads_read, business_management
META_ADS_TOKEN=
# 광고 관리자 주소창의 act= 뒤 숫자만
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# 손익분기 결과당 비용을 센트로. $13 이면 1300
# 하루 예산 상한 = 이 값 x 7 (guards.py 가 강제)
BEP_CENTS=1300

# 그림 생성 (장당 요금)
OPENAI_API_KEY=

# 알림은 안 쓴다. 결과는 out/보고서.html 을 열어서 본다.
# 텔레그램·메일로 받고 싶으면 factory.py 5단계 뒤에 함수 하나만 더하면 된다.
